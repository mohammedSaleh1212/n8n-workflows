        "jsCode": "// Bulletproof JSON Extraction\nlet raw = $json.output || \"\";\nlet response = {\n  reply: \"I'm having a technical hiccup. Could you try that again?\",\n  success: false,\n  raw_output: raw\n};\n\ntry {\n  // 1. Clean the fluff\n  let cleaned = raw.replace(/```json/g, '').replace(/```/g, '').trim();\n  \n  // 2. Extract the object\n  const start = cleaned.indexOf('{');\n  const end = cleaned.lastIndexOf('}');\n\n  if (start !== -1 && end !== -1) {\n    const jsonString = cleaned.substring(start, end + 1);\n    const parsed = JSON.parse(jsonString);\n    \n    if (parsed.reply) {\n      response.reply = parsed.reply;\n      response.success = true;\n    }\n  }\n} catch (e) {\n  // Log the error internally but don't crash the node\n  response.error_details = e.message;\n}\n\nreturn response;"
