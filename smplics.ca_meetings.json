    {
      "parameters": {
        "jsCode": "const serviceId = $('set data coming from the client').first().json.service;\nconst name = $('set data coming from the client').first().json.customer_name;\nconst adminTz = $('set data coming from the client').first().json.admin_time_zone;\nconst adminTime = $('Code in JavaScript4').first().json.meeting_start_time_admin;\n\n// --- Service Templates ---\nconst serviceTemplates = {\n  \"ai-receptionists\": {\n    subject: \"Confirmation: AI Receptionist Consultation\",\n    description: \"Thank you for your interest in our 24/7 AI Receptionists. We look forward to discussing how automated call handling and lead capture can streamline your front desk operations.\"\n  },\n  \"high-end-web-design\": {\n    subject: \"Confirmation: Premium Web Design Strategy Session\",\n    description: \"Your session regarding High-End Web Design is confirmed. We are excited to show you how conversion-focused architecture can turn your visitors into loyal customers.\"\n  },\n  \"review-generation\": {\n    subject: \"Confirmation: 5-Star Review Generation Planning\",\n    description: \"We’ve received your request for our Review Generation system. We’ll be discussing how to automate your social proof and skyrocket your local SEO rankings.\"\n  },\n  \"google-ads\": {\n    subject: \"Confirmation: Google Ads Management Strategy\",\n    description: \"Your consultation for Google Ads is set. Our goal is to review your current ad spend and plan a campaign that puts your business at the top of search results.\"\n  },\n  \"seo-optimization\": {\n    subject: \"Confirmation: Organic SEO Growth Session\",\n    description: \"We are ready to dive into your SEO Optimization strategy. We will focus on improving your technical structure and long-term organic visibility.\"\n  },\n  \"default\": {\n    subject: \"Appointment Confirmation: Smplics Solutions\",\n    description: \"This is a formal confirmation of your scheduled meeting with our team. We look forward to discussing your business requirements and growth goals.\"\n  }\n};\n\nconst content = serviceTemplates[serviceId] || serviceTemplates[\"default\"];\n\nreturn {\n  emailSubject: content.subject,\n  emailBody: `Dear ${name},\\n\\n${content.description}\\n\\nWe look forward to our session.\\n\\nBest regards,\\nSmplics Solutions Team`,\n\n  adminSubject: `NEW BOOKING: ${name} (${serviceId})`,\n  adminBody: `Action Required: A new meeting has been scheduled.\\n\\nCustomer Name: ${name}\\nService: ${serviceId}\\nTime: ${adminTime} (${adminTz})\\n\\nPlease check the Google Calendar for details.`\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1152,
        304
      ],
      "id": "7e6a55cc-bffd-4570-9a8a-51ac8e22a317",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// ================= CONFIG =================\nconst SLOT_MINUTES = 30;\nconst WORK_START_HOUR_UTC = 6;\nconst WORK_END_HOUR_UTC = 14;\nconst NO_WORK_DAY_UTC = 5; // Friday\n\n// Get boundaries from your Webhook\nconst rangeStartStr = $('Webhook').first().json.body.rangeStart;\nconst rangeEndStr = $('Webhook').first().json.body.rangeEnd;\n\nconst rangeStart = new Date(rangeStartStr);\nconst rangeEnd = new Date(rangeEndStr);\nconst now = new Date(); \n// =========================================\n\n// --- THE FIX IS HERE ---\n// Your JSON uses \"meeting_slots\", not \"busy\"\nconst inputData = items[0].json.meeting_slots || [];\n\nconst busySlots = inputData.map(s => ({\n  start: new Date(s.start),\n  end: new Date(s.end),\n}));\n\n// Overlap check helper\nconst overlaps = (aStart, aEnd, bStart, bEnd) => aStart < bEnd && aEnd > bStart;\n\nconst results = [];\nconst cursor = new Date(rangeStart);\n\nwhile (cursor < rangeEnd) {\n  const dayOfWeekUTC = cursor.getUTCDay();\n\n  if (dayOfWeekUTC === NO_WORK_DAY_UTC) {\n    cursor.setUTCDate(cursor.getUTCDate() + 1);\n    continue;\n  }\n\n  const dayStart = new Date(cursor);\n  dayStart.setUTCHours(WORK_START_HOUR_UTC, 0, 0, 0);\n\n  const dayEnd = new Date(cursor);\n  dayEnd.setUTCHours(WORK_END_HOUR_UTC, 0, 0, 0);\n\n  const slots = [];\n  let slotStart = new Date(dayStart);\n\n  while (slotStart < dayEnd) {\n    const slotEnd = new Date(slotStart.getTime() + SLOT_MINUTES * 60000);\n\n    if (slotEnd > dayEnd) break;\n\n    // This now correctly references the busySlots mapped above\n    const isBusy = busySlots.some(busy =>\n      overlaps(slotStart, slotEnd, busy.start, busy.end)\n    );\n\n    if (!isBusy && slotStart > now && slotStart >= rangeStart) {\n      slots.push(slotStart.toISOString());\n    }\n\n    slotStart = slotEnd;\n  }\n\n  if (slots.length > 0) {\n    results.push({\n      date: cursor.toISOString().substring(0, 10),\n      slots,\n    });\n  }\n\n  cursor.setUTCDate(cursor.getUTCDate() + 1);\n}\n\nreturn results.map(r => ({ json: r }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
