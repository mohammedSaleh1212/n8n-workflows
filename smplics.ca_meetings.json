    {
      "parameters": {
        "jsCode": "// Access the admin timezone once from the first item\nconst adminTimeZone = $input.first().json.admin_time_zone || 'Asia/Dubai'; \n\nreturn items.map(item => {\n  const isoString = item.json.meeting_start_time; \n  const userTimeZone = item.json.user_time_zone || 'UTC'; \n  \n  const date = new Date(isoString);\n\n  // Common options for formatting\n  const getOptions = (tz) => ({\n    weekday: 'long',\n    year: 'numeric',\n    month: 'long',\n    day: 'numeric',\n    hour: 'numeric',\n    minute: '2-digit',\n    hour12: true,\n    timeZone: tz\n  });\n\n  // User formatting\n  const userReadable = new Intl.DateTimeFormat('en-US', getOptions(userTimeZone)).format(date);\n\n  // Admin formatting (Dubai)\n  const adminReadable = new Intl.DateTimeFormat('en-US', getOptions(adminTimeZone)).format(date);\n\n  return {\n    json: {\n      ...item.json,\n      meeting_start_time_local: userReadable,\n      meeting_start_time_admin: adminReadable // New value for the Dubai admin\n    }\n  };\n});"
      },
