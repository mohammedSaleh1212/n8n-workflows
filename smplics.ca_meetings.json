        "message": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Meeting Invitation</title>\n</head>\n<body style=\"margin: 0; padding: 0; font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; background-color: #f8f9fa; line-height: 1.6;\">\n    \n    <!-- Main container -->\n    <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width: 600px; margin: 0 auto; background-color: #ffffff;\">\n        <!-- Orange header -->\n        <tr>\n            <td style=\"background-color: #292824; padding: 30px 20px; text-align: center;\">\n<img src=\"https://res.cloudinary.com/dfmjuyexh/image/upload/v1769438541/smplicslogoGmail_ircxmu.png\" \n     alt=\"Test Logo\" \n     style=\"height: 40px; width: auto;\">\n\n                <h1 style=\"color: #ffffff; font-size: 24px; font-weight: 600; margin: 0; padding: 0;\">Meeting Invitation</h1>\n                <p style=\"color: rgba(255, 255, 255, 0.9); font-size: 14px; margin: 10px 0 0 0;\">You've been invited to a meeting</p>\n            </td>\n        </tr>\n        \n        <!-- Content area -->\n        <tr>\n            <td style=\"padding: 40px 30px;\">\n                <!-- Main meeting info -->\n                <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n                    <tr>\n                        <td style=\"padding-bottom: 30px;\">\n                            <h2 style=\"color: #333333; font-size: 20px; font-weight: 600; margin: 0 0 10px 0; border-bottom: 2px solid #ee7639; padding-bottom: 10px;\">\n                                Meeting Details\n                            </h2>\n                        </td>\n                    </tr>\n                    \n                    <!-- Description -->\n                    <tr>\n                        <td style=\"padding-bottom: 15px;\">\n                            <div style=\"background-color: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #ee7639;\">\n                                <div style=\"color: #ee7639; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;\">Description</div>\n                                <div style=\"color: #555555; font-size: 15px; line-height: 1.6;\">\n{{ $json.emailBody }}\n                                </div>\n                            </div>\n                        </td>\n                    </tr>\n                    \n                    <!-- Date & Time -->\n                    <tr>\n                        <td style=\"padding-bottom: 15px;\">\n                            <div style=\"background-color: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #ee7639;\">\n                                <div style=\"color: #ee7639; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;\">Date & Time</div>\n                                <div style=\"color: #333333; font-size: 16px; font-weight: 500; margin-bottom: 5px;\">\n                                    {{ $('Code in JavaScript4').item.json.meeting_start_time_local }}\n                                </div>\n                                <div style=\"color: #666666; font-size: 14px;\">\n                                    {{ $('Code in JavaScript4').item.json.user_time_zone }} timezone\n                                </div>\n                            </div>\n                        </td>\n                    </tr>\n                    \n                    <!-- Organizer -->\n                    <tr>\n                        <td style=\"padding-bottom: 15px;\">\n                            <div style=\"background-color: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #ee7639;\">\n                                <div style=\"color: #ee7639; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;\">Organizer</div>\n                                <div style=\"color: #333333; font-size: 16px; font-weight: 500; word-break: break-all;\">{{ $('Create an event1').item.json.creator.email }}\n          \n                                </div>\n                            </div>\n                        </td>\n                    </tr>\n                    \n                    <!-- Attendee (You) -->\n                    <tr>\n                        <td style=\"padding-bottom: 15px;\">\n                            <div style=\"background-color: #f8f9fa; padding: 20px; border-radius: 8px; border-left: 4px solid #ee7639;\">\n                                <div style=\"color: #ee7639; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px;\">You</div>\n                                <div style=\"color: #333333; font-size: 16px; font-weight: 500; word-break: break-all;\">\n{{ $('Create an event1').item.json.attendees[0].email }}\n                                </div>\n                            </div>\n                        </td>\n                    </tr>\n                </table>\n                \n                <!-- Join Button -->\n                <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin: 40px 0;\">\n                    <tr>\n                        <td align=\"center\">\n                            <a href=\"{{ $('Create an event1').item.json.conferenceData.entryPoints[0].uri }}\" \n                               style=\"display: inline-block; background-color: #ee7639; color: #ffffff; text-decoration: none; padding: 16px 40px; border-radius: 50px; font-weight: 600; font-size: 16px; letter-spacing: 0.5px; box-shadow: 0 4px 15px rgba(238, 118, 57, 0.3);\">\n                                Join Google Meet\n                            </a>\n                        </td>\n                    </tr>\n                    <tr>\n                        <td align=\"center\" style=\"padding-top: 15px;\">\n                            <a href=\"{{ $('Create an event1').item.json.conferenceData.entryPoints[0].uri }}\" \n                               style=\"color: #ee7639; font-size: 14px; text-decoration: none; word-break: break-all; display: inline-block; max-width: 90%;\">{{ $('Create an event1').item.json.conferenceData.entryPoints[0].uri }}\n                           \n                            </a>\n                        </td>\n                    </tr>\n                </table>\n                \n                <!-- Help text -->\n                <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n                    <tr>\n                        <td style=\"padding-top: 30px; border-top: 1px solid #e9ecef;\">\n                            <p style=\"color: #666666; font-size: 14px; line-height: 1.5; margin: 0; text-align: center;\">\n                                Please join the meeting on time. If you're unable to attend or have questions, \n                                please contact the organizer directly.\n                            </p>\n                        </td>\n                    </tr>\n                </table>\n            </td>\n        </tr>\n        \n        <!-- Footer -->\n        <tr>\n            <td style=\"background-color: #292824; padding: 30px 20px; text-align: center;\">\n                <!-- Contact link only -->\n                <div style=\"margin-bottom: 15px;\">\n                    <a href=\"https://smplicsai.com/contact\" \n                       style=\"color: #ee7639; text-decoration: none; font-size: 14px; font-weight: 500; display: inline-block;\">\n                        Contact Us\n                    </a>\n                </div>\n                \n                <!-- Copyright -->\n                <div style=\"color: #adb5bd; font-size: 12px; margin-top: 10px;\">\n                    &copy; {{ new Date().getFullYear() }} Smplics. All rights reserved.\n                </div>\n            </td>\n        </tr>\n    </table>\n    \n</body>\n</html>\n",
        "options": {
